{
  "build": {
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist/financeiro-angular/browser"
  },
  "package": {
    "productName": "financeiro-angular",
    "version": "1.0.1"
  },
  "tauri": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://www.dropbox.com/scl/fi/q5j4v83bf4wkhhrjawfzb/updater.json?rlkey=bu9hw129y8hvj7pplbrg2j4nt&st=16nj9new&dl=0"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2MTgzMUUwMjYwRTkzMzQKUldRMGt3NG00REVZbGwvL1FaVmF2bnRBc0ppdWdvTlpYZmdxUzJJc1VuWVhFK2J6RVh4ZE5VTkYK"
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "path": {
        "all": true
      },
      "dialog": {
        "all": true,
        "ask": true,
        "confirm": true,
        "message": true,
        "open": true,
        "save": true
      },
      "fs": {
        "readFile": true
      }
    },
    "windows": [
      {
        "title": "financeiro",
        "width": 1400,
        "height": 1000,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.financeiro",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}

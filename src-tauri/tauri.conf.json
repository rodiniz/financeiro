      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "financeiro-angular",
  "mainBinaryName": "financeiro-angular",
  "version": "1.1.0",
  "identifier": "com.financeiro",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4RjY2Qzk5NDU2RjlCMUMKUldRY20yOUZtV3oycUxyamFiNWlidHVqeHd5TXdGdU8xQytENFN2aEpod0FRWERlaW51VEp6TWwK",
      "endpoints": [
        "https://github.com/rodiniz/financeiro/releases/download/latest/financeiro-angular-{{target}}.{{arch}}"
      ]
    }
  },
  "app": {

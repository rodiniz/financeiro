{
  "build": {
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/financeiro-angular/browser",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "financeiro-angular",
  "mainBinaryName": "financeiro-angular",
  "version": "1.0.1",
  "identifier": "com.financeiro",
  "plugins": {
   
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "financeiro",
        "width": 1400,
        "height": 2000,
        "fullscreen": false,
        "useHttpsScheme": true
      }
    ]
  }
}